manifest := "skills.json"
skills_dir := "skills"

# Refresh upstream Claude skills from skills.json (all, or one by name).
refresh-skills name="":
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{justfile_directory()}}"
    target="{{name}}"

    while IFS=$'\t' read -r repo lic subpath; do
        skill="$(basename "$subpath")"
        if [[ -n "$target" && "$target" != "$skill" ]]; then
            continue
        fi

        slug="${repo#https://github.com/}"
        owner="${slug%%/*}"
        reponame="${slug#*/}"; reponame="${reponame%%/*}"

        echo ">> $skill  <-  $owner/$reponame:$subpath"
        branch="$(gh api "repos/$owner/$reponame" --jq '.default_branch')"

        mapfile -t files < <(gh api "repos/$owner/$reponame/git/trees/$branch?recursive=1" \
            | jq -r --arg sp "$subpath" '.tree[] | select(.type=="blob" and (.path | startswith($sp + "/"))) | .path')
        if [[ "${#files[@]}" -eq 0 ]]; then
            echo "!! no files under $subpath" >&2
            exit 1
        fi

        dest="{{skills_dir}}/$skill"
        rm -rf "$dest"

        has_skill=0 has_license=0
        for path in "${files[@]}"; do
            rel="${path#"$subpath"/}"
            out="$dest/$rel"
            mkdir -p "$(dirname "$out")"
            gh api -H "Accept: application/vnd.github.raw" \
                "repos/$owner/$reponame/contents/$path?ref=$branch" > "$out"
            [[ "$rel" == "SKILL.md" ]] && has_skill=1
            [[ "$rel" == "LICENSE" ]] && has_license=1
        done

        if [[ "$has_skill" -eq 0 ]]; then
            echo "!! $skill has no SKILL.md" >&2
            exit 1
        fi

        if [[ "$has_license" -eq 0 ]]; then
            gh api -H "Accept: application/vnd.github.raw" \
                "repos/$owner/$reponame/contents/${lic#/}?ref=$branch" > "$dest/LICENSE" || true
            if [[ ! -s "$dest/LICENSE" ]]; then
                echo "!! license fetch failed or empty for $skill ($lic)" >&2
                exit 1
            fi
        fi

        echo "   ok ($((${#files[@]})) files)"
    done < <(jq -r 'to_entries[] | .value.license as $lic | .key as $repo | .value.skills[] | "\($repo)\t\($lic)\t\(.)"' "{{manifest}}")
